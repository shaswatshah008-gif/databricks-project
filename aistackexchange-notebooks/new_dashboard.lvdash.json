      "displayName": "views_per_month",
      "queryLines": [
        "SELECT\r\n",
        "    TO_DATE(DATE_TRUNC('month', PostCreationDate)) AS Month,\r\n",
        "    SUM(Views) AS TotalViews\r\n",
        "FROM\r\n",
        "    marts_posts_users\r\n",
        "GROUP BY \r\n",
        "    TO_DATE(DATE_TRUNC('month', PostCreationDate))\r\n",
        "ORDER BY\r\n",
        "    Month"
      ],
      "catalog": "stackexchange_dataset",
      "schema": "default"
    }
